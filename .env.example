# ─────────────────────────────────────────────────
#  Cricket Backend — Environment Variables
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to git!
# ─────────────────────────────────────────────────

# Your RapidAPI key for CricBuzz Cricket API
# Get one free at: https://rapidapi.com/cricketapilive/api/cricbuzz-cricket
RAPIDAPI_KEY=your_rapidapi_key_here

# Server port (Railway / Render sets this automatically)
PORT=3000

# Allowed Flutter app origin (set to * for open access, or your domain)
CORS_ORIGIN=*

# ── Polling intervals (in seconds) ──────────────
# How often to fetch live match data from CricBuzz
LIVE_POLL_SECONDS=30

# How often to fetch upcoming matches
UPCOMING_POLL_SECONDS=300

# How often to fetch recent matches
RECENT_POLL_SECONDS=600

# How often to fetch rankings (1 hour)
RANKINGS_POLL_SECONDS=3600

# ── Optional Redis (leave blank to use in-memory cache) ──
# REDIS_URL=redis://localhost:6379
